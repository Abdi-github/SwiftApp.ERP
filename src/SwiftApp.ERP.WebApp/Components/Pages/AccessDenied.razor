@page "/access-denied"
@layout SwiftApp.ERP.WebApp.Components.Layout.LoginLayout

<PageTitle>Access Denied — SwiftApp ERP</PageTitle>

<div class="card shadow" style="width: 420px;">
    <div class="card-body p-4 text-center">
        <i class="bi bi-shield-lock text-danger" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Access Denied</h3>
        <p class="text-muted">You do not have permission to access this resource.</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/app/dashboard" class="btn btn-primary">
                <i class="bi bi-house me-1"></i> Dashboard
            </a>
            <a href="/logout" class="btn btn-outline-secondary">
                <i class="bi bi-box-arrow-right me-1"></i> Sign Out
            </a>
        </div>
    </div>
</div>
