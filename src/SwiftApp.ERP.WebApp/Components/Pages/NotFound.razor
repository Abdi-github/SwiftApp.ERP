@page "/not-found"
@layout SwiftApp.ERP.WebApp.Components.Layout.LoginLayout

<PageTitle>Page Not Found — SwiftApp ERP</PageTitle>

<div class="card shadow" style="width: 420px;">
    <div class="card-body p-4 text-center">
        <i class="bi bi-search text-warning" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Page Not Found</h3>
        <p class="text-muted">The page you are looking for does not exist or has been moved.</p>
        <a href="/app/dashboard" class="btn btn-primary">
            <i class="bi bi-house me-1"></i> Dashboard
        </a>
    </div>
</div>
