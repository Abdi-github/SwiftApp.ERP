@page "/error"
@layout SwiftApp.ERP.WebApp.Components.Layout.LoginLayout

<PageTitle>Error — SwiftApp ERP</PageTitle>

<div class="card shadow" style="width: 480px;">
    <div class="card-body p-4 text-center">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Something Went Wrong</h3>
        <p class="text-muted">An unexpected error occurred. Please try again or contact support if the problem persists.</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/app/dashboard" class="btn btn-primary">
                <i class="bi bi-house me-1"></i> Dashboard
            </a>
            <button class="btn btn-outline-secondary" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise me-1"></i> Retry
            </button>
        </div>
    </div>
</div>
