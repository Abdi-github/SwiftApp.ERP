@page "/app/hr/departments/new"
@page "/app/hr/departments/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Hr.Application.DTOs
@using SwiftApp.ERP.Modules.Hr.Application.Services
@attribute [Authorize(Policy = "HR:CREATE")]
@rendermode InteractiveServer
@inject DepartmentService DepartmentService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Edit Department" : "New Department") — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3 me-2"></i>@(_isEdit ? "Edit Department" : "New Department")</h2>
    <a href="/app/hr/departments" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Departments
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="departmentForm">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Code <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Code" />
                </div>
                <div class="col-md-8 mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Name" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" />
            </div>
            <div class="form-check mb-3">
                <InputCheckbox class="form-check-input" @bind-Value="_model.Active" />
                <label class="form-check-label">Active</label>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Update" : "Create")
                </button>
                <a href="/app/hr/departments" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private DepartmentFormModel _model = new();
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var d = await DepartmentService.GetByIdAsync(Id!.Value);
            if (d is null) { Navigation.NavigateTo("/app/hr/departments"); return; }
            _model = new DepartmentFormModel
            {
                Code = d.Code, Name = d.Name, Description = d.Description, Active = d.Active,
            };
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true; _error = null;
        try
        {
            var request = new DepartmentRequest(
                _model.Code ?? "", _model.Name ?? "", _model.Description,
                null, _model.Active, null, null);

            if (_isEdit) await DepartmentService.UpdateAsync(Id!.Value, request);
            else await DepartmentService.CreateAsync(request);

            Navigation.NavigateTo("/app/hr/departments");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private class DepartmentFormModel
    {
        public string? Code { get; set; }
        public string? Name { get; set; }
        public string? Description { get; set; }
        public bool Active { get; set; } = true;
    }
}
