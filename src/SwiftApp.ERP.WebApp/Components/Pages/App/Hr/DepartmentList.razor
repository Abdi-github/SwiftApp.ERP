@page "/app/hr/departments"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Hr.Application.DTOs
@using SwiftApp.ERP.Modules.Hr.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "HR:VIEW")]
@rendermode InteractiveServer
@inject DepartmentService DepartmentService

<PageTitle>Departments — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3 me-2"></i>Departments</h2>
    <AuthorizeView Policy="HR:CREATE">
        <a href="/app/hr/departments/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Department
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search departments..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No departments found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("Code")'>Code @SortIcon("Code")</th>
                            <th role="button" @onclick='() => ToggleSort("Name")'>Name @SortIcon("Name")</th>
                            <th>Description</th>
                            <th>Manager</th>
                            <th role="button" @onclick='() => ToggleSort("EmployeeCount")'>Employees @SortIcon("EmployeeCount")</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _sorted)
                        {
                            <tr>
                                <td><code>@d.Code</code></td>
                                <td>@d.Name</td>
                                <td>@(d.Description ?? "—")</td>
                                <td>@(d.ManagerName ?? "—")</td>
                                <td><span class="badge bg-secondary">@d.EmployeeCount</span></td>
                                <td>
                                    @if (d.Active) { <span class="badge bg-success">Active</span> }
                                    else { <span class="badge bg-danger">Inactive</span> }
                                </td>
                                <td class="text-end">
                                    <AuthorizeView Policy="HR:EDIT">
                                        <a href="/app/hr/departments/edit/@d.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int p = 1; p <= _result.TotalPages; p++) { var pg = p; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<DepartmentResponse>? _result;
    private List<DepartmentResponse> _sorted = [];
    private string? _search;
    private string _sortCol = "Code";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await DepartmentService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        _sorted = (_sortCol switch
        {
            "Code" => _sortAsc ? _result.Items.OrderBy(d => d.Code) : _result.Items.OrderByDescending(d => d.Code),
            "Name" => _sortAsc ? _result.Items.OrderBy(d => d.Name) : _result.Items.OrderByDescending(d => d.Name),
            "EmployeeCount" => _sortAsc ? _result.Items.OrderBy(d => d.EmployeeCount) : _result.Items.OrderByDescending(d => d.EmployeeCount),
            _ => _result.Items.AsEnumerable()
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
