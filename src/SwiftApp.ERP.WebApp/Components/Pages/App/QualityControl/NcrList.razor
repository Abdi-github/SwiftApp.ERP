@page "/app/qc/ncrs"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.QualityControl.Application.DTOs
@using SwiftApp.ERP.Modules.QualityControl.Application.Services
@using SwiftApp.ERP.Modules.QualityControl.Domain.Enums
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "QC:VIEW")]
@rendermode InteractiveServer
@inject NonConformanceReportService NcrService

<PageTitle>Non-Conformance Reports — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-exclamation-triangle me-2"></i>Non-Conformance Reports</h2>
    <AuthorizeView Policy="QC:CREATE">
        <a href="/app/qc/ncrs/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New NCR
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search NCRs..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Closed">Closed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_severityFilter" @bind:after="OnFilterChanged">
                    <option value="">All Severities</option>
                    <option value="Minor">Minor</option>
                    <option value="Major">Major</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No non-conformance reports found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("NcrNumber")'>NCR # @SortIcon("NcrNumber")</th>
                            <th>Check #</th>
                            <th role="button" @onclick='() => ToggleSort("Severity")'>Severity @SortIcon("Severity")</th>
                            <th role="button" @onclick='() => ToggleSort("Status")'>Status @SortIcon("Status")</th>
                            <th>Responsible</th>
                            <th role="button" @onclick='() => ToggleSort("DueDate")'>Due Date @SortIcon("DueDate")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ncr in _sorted)
                        {
                            <tr>
                                <td><code>@ncr.NcrNumber</code></td>
                                <td>@(ncr.CheckNumber ?? "—")</td>
                                <td><span class="badge @SeverityBadge(ncr.Severity)">@ncr.Severity</span></td>
                                <td><span class="badge @StatusBadge(ncr.Status)">@ncr.Status</span></td>
                                <td>@(ncr.ResponsiblePerson ?? "—")</td>
                                <td>@(ncr.DueDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                                <td class="text-end">
                                    @if (ncr.Status == "Open")
                                    {
                                        <AuthorizeView Policy="QC:CREATE">
                                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => StartNcr(ncr.Id)" title="Start">
                                                <i class="bi bi-play-fill"></i>
                                            </button>
                                        </AuthorizeView>
                                    }
                                    @if (ncr.Status == "InProgress")
                                    {
                                        <AuthorizeView Policy="QC:CREATE">
                                            <button class="btn btn-sm btn-outline-success me-1" @onclick="() => CloseNcr(ncr.Id)" title="Close">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        </AuthorizeView>
                                    }
                                    <AuthorizeView Policy="QC:EDIT">
                                        <a href="/app/qc/ncrs/edit/@ncr.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="QC:DELETE">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(ncr)"><i class="bi bi-trash"></i></button>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int i = 1; i <= _result.TotalPages; i++) { var pg = i; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@if (_deleteTarget is not null)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete NCR <strong>@_deleteTarget.NcrNumber</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@_deleting">
                        @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<NcrResponse>? _result;
    private List<NcrResponse> _sorted = [];
    private string? _search;
    private string _statusFilter = "";
    private string _severityFilter = "";
    private string _sortCol = "NcrNumber";
    private bool _sortAsc;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private NcrResponse? _deleteTarget;
    private bool _deleting;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await NcrService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        IEnumerable<NcrResponse> items = _result.Items;
        if (!string.IsNullOrEmpty(_statusFilter))
            items = items.Where(n => n.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(_severityFilter))
            items = items.Where(n => n.Severity.Equals(_severityFilter, StringComparison.OrdinalIgnoreCase));
        _sorted = (_sortCol switch
        {
            "NcrNumber" => _sortAsc ? items.OrderBy(n => n.NcrNumber) : items.OrderByDescending(n => n.NcrNumber),
            "Severity" => _sortAsc ? items.OrderBy(n => n.Severity) : items.OrderByDescending(n => n.Severity),
            "Status" => _sortAsc ? items.OrderBy(n => n.Status) : items.OrderByDescending(n => n.Status),
            "DueDate" => _sortAsc ? items.OrderBy(n => n.DueDate) : items.OrderByDescending(n => n.DueDate),
            _ => items
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");
    private async Task OnFilterChanged() { _page = 1; ApplyClientSort(); await Task.CompletedTask; }

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }

    private async Task StartNcr(Guid id) { await NcrService.StartAsync(id); await LoadData(); }
    private async Task CloseNcr(Guid id) { await NcrService.CloseAsync(id); await LoadData(); }

    private void ConfirmDelete(NcrResponse ncr) => _deleteTarget = ncr;
    private void CancelDelete() => _deleteTarget = null;

    private async Task ExecuteDelete()
    {
        if (_deleteTarget is null) return;
        _deleting = true;
        try { await NcrService.DeleteAsync(_deleteTarget.Id); _deleteTarget = null; await LoadData(); }
        finally { _deleting = false; }
    }

    private static string SeverityBadge(string severity) => severity switch
    {
        "Minor" => "bg-info text-dark",
        "Major" => "bg-warning text-dark",
        "Critical" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string StatusBadge(string status) => status switch
    {
        "Open" => "bg-primary",
        "InProgress" => "bg-warning text-dark",
        "Closed" => "bg-success",
        _ => "bg-secondary"
    };
}
