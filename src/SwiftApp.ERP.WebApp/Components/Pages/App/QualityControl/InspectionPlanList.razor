@page "/app/qc/inspections"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.QualityControl.Application.DTOs
@using SwiftApp.ERP.Modules.QualityControl.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "QC:VIEW")]
@rendermode InteractiveServer
@inject InspectionPlanService InspectionPlanService

<PageTitle>Inspection Plans — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-clipboard-check me-2"></i>Inspection Plans</h2>
    <AuthorizeView Policy="QC:CREATE">
        <a href="/app/qc/inspections/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Plan
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search plans..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No inspection plans found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("PlanNumber")'>Plan # @SortIcon("PlanNumber")</th>
                            <th role="button" @onclick='() => ToggleSort("Name")'>Name @SortIcon("Name")</th>
                            <th>Description</th>
                            <th role="button" @onclick='() => ToggleSort("Frequency")'>Frequency @SortIcon("Frequency")</th>
                            <th role="button" @onclick='() => ToggleSort("Active")'>Active @SortIcon("Active")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in _sorted)
                        {
                            <tr>
                                <td><code>@plan.PlanNumber</code></td>
                                <td>@plan.Name</td>
                                <td class="text-truncate" style="max-width: 250px;">@plan.Description</td>
                                <td><span class="badge bg-info">@plan.Frequency</span></td>
                                <td><span class="badge @(plan.Active ? "bg-success" : "bg-secondary")">@(plan.Active ? "Active" : "Inactive")</span></td>
                                <td class="text-end">
                                    <AuthorizeView Policy="QC:EDIT">
                                        <a href="/app/qc/inspections/edit/@plan.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int i = 1; i <= _result.TotalPages; i++) { var pg = i; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<InspectionPlanResponse>? _result;
    private List<InspectionPlanResponse> _sorted = [];
    private string? _search;
    private string _statusFilter = "";
    private string _sortCol = "PlanNumber";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await InspectionPlanService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        IEnumerable<InspectionPlanResponse> items = _result.Items;
        if (_statusFilter == "active") items = items.Where(p => p.Active);
        else if (_statusFilter == "inactive") items = items.Where(p => !p.Active);
        _sorted = (_sortCol switch
        {
            "PlanNumber" => _sortAsc ? items.OrderBy(p => p.PlanNumber) : items.OrderByDescending(p => p.PlanNumber),
            "Name" => _sortAsc ? items.OrderBy(p => p.Name) : items.OrderByDescending(p => p.Name),
            "Frequency" => _sortAsc ? items.OrderBy(p => p.Frequency) : items.OrderByDescending(p => p.Frequency),
            "Active" => _sortAsc ? items.OrderBy(p => p.Active) : items.OrderByDescending(p => p.Active),
            _ => items
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");
    private async Task OnFilterChanged() { _page = 1; await LoadData(); }

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
