@page "/app/qc/inspections/new"
@page "/app/qc/inspections/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.QualityControl.Application.DTOs
@using SwiftApp.ERP.Modules.QualityControl.Application.Services
@attribute [Authorize(Policy = "QC:CREATE")]
@rendermode InteractiveServer
@inject InspectionPlanService InspectionPlanService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Edit Inspection Plan" : "New Inspection Plan") — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-clipboard-check me-2"></i>@(_isEdit ? "Edit Inspection Plan" : "New Inspection Plan")</h2>
    <a href="/app/qc/inspections" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Plans
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="inspectionPlanForm">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Name" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Frequency</label>
                    <InputSelect class="form-select" @bind-Value="_model.Frequency">
                        <option value="">— Select Frequency —</option>
                        <option value="Per Batch">Per Batch</option>
                        <option value="Daily">Daily</option>
                        <option value="Weekly">Weekly</option>
                        <option value="Monthly">Monthly</option>
                        <option value="Quarterly">Quarterly</option>
                        <option value="Annual">Annual</option>
                    </InputSelect>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" />
            </div>
            <div class="mb-3">
                <label class="form-label">Criteria</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Criteria" placeholder="Quality check criteria..." />
            </div>
            <div class="form-check mb-3">
                <InputCheckbox class="form-check-input" @bind-Value="_model.Active" />
                <label class="form-check-label">Active</label>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Update" : "Create")
                </button>
                <a href="/app/qc/inspections" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private InspectionPlanFormModel _model = new();
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var plan = await InspectionPlanService.GetByIdAsync(Id!.Value);
            if (plan is null) { Navigation.NavigateTo("/app/qc/inspections"); return; }
            _model = new InspectionPlanFormModel
            {
                Name = plan.Name, Description = plan.Description,
                Criteria = plan.Criteria, Frequency = plan.Frequency,
                Active = plan.Active,
            };
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true; _error = null;
        try
        {
            var request = new InspectionPlanRequest(
                _model.Name, _model.Description, null, null,
                _model.Criteria, _model.Frequency, _model.Active);

            if (_isEdit) await InspectionPlanService.UpdateAsync(Id!.Value, request);
            else await InspectionPlanService.CreateAsync(request);

            Navigation.NavigateTo("/app/qc/inspections");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private class InspectionPlanFormModel
    {
        public string? Name { get; set; } = "";
        public string? Description { get; set; }
        public string? Criteria { get; set; }
        public string? Frequency { get; set; }
        public bool Active { get; set; } = true;
    }
}
