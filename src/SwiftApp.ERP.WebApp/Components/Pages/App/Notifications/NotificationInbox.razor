@page "/app/notifications"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject SwiftApp.ERP.Modules.Notification.Application.Services.NotificationService NotificationService

<PageTitle>Notifications — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-bell me-2"></i>Notifications</h2>
    <div class="d-flex gap-2">
        @if (_unreadCount > 0)
        {
            <button class="btn btn-outline-primary btn-sm" @onclick="MarkAllRead">
                <i class="bi bi-check2-all me-1"></i>Mark all as read
            </button>
        }
    </div>
</div>

@* Filter tabs *@
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_filter == Filter.All ? "active" : "")" @onclick="() => SetFilter(Filter.All)">
            All
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_filter == Filter.Unread ? "active" : "")" @onclick="() => SetFilter(Filter.Unread)">
            Unread
            @if (_unreadCount > 0)
            {
                <span class="badge bg-danger ms-1">@_unreadCount</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_filter == Filter.Read ? "active" : "")" @onclick="() => SetFilter(Filter.Read)">
            Read
        </button>
    </li>
</ul>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_notifications.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-bell-slash fs-1 text-muted d-block mb-2"></i>
        <p class="text-muted">No notifications found</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var n in _notifications)
        {
            <div class="list-group-item list-group-item-action @(n.ReadAt is null ? "border-start border-primary border-3" : "")">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center @(n.ReadAt is null ? "bg-primary text-white" : "bg-light text-muted")" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="bi @GetIcon(n.ReferenceType)"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-1 @(n.ReadAt is null ? "fw-bold" : "")">@n.Subject</h6>
                                <p class="mb-1 text-muted small">@n.Body</p>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>@FormatTimeAgo(n.CreatedAt)
                                    @if (!string.IsNullOrEmpty(n.ReferenceType))
                                    {
                                        <span class="ms-2 badge bg-secondary bg-opacity-10 text-secondary">@n.ReferenceType</span>
                                    }
                                    <span class="ms-2 badge @GetStatusBadge(n.Status)">@n.Status</span>
                                </small>
                            </div>
                            <div class="d-flex gap-1">
                                @if (n.ReadAt is null)
                                {
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => MarkRead(n.Id)" title="Mark as read">
                                        <i class="bi bi-check2"></i>
                                    </button>
                                }
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Dismiss(n.Id)" title="Dismiss">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Pagination *@
    @if (_totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button>
                </li>
                @for (var i = 1; i <= _totalPages; i++)
                {
                    var pg = i;
                    <li class="page-item @(pg == _page ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                    </li>
                }
                <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private enum Filter { All, Unread, Read }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private Guid? _userId;
    private List<SwiftApp.ERP.Modules.Notification.Application.DTOs.NotificationResponse> _notifications = [];
    private long _unreadCount;
    private int _page = 1;
    private int _totalPages = 1;
    private const int PageSize = 15;
    private Filter _filter = Filter.All;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var sub = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (Guid.TryParse(sub, out var id))
                _userId = id;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_userId is null) return;
        _loading = true;

        bool? unreadOnly = _filter switch
        {
            Filter.Unread => true,
            _ => null
        };

        var result = await NotificationService.GetByUserAsync(_userId.Value, _page, PageSize, unreadOnly, default);

        // For the "Read" filter, show only read items (filter client-side from full list)
        if (_filter == Filter.Read)
        {
            _notifications = result.Items.Where(n => n.ReadAt is not null).ToList();
        }
        else
        {
            _notifications = result.Items.ToList();
        }

        _totalPages = result.TotalPages;
        _unreadCount = await NotificationService.CountUnreadAsync(_userId.Value, default);
        _loading = false;
    }

    private async Task SetFilter(Filter filter)
    {
        _filter = filter;
        _page = 1;
        await LoadAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _page = page;
        await LoadAsync();
    }

    private async Task MarkRead(Guid id)
    {
        await NotificationService.MarkReadAsync(id, default);
        await LoadAsync();
    }

    private async Task MarkAllRead()
    {
        if (_userId is null) return;
        await NotificationService.MarkAllReadAsync(_userId.Value, default);
        await LoadAsync();
    }

    private async Task Dismiss(Guid id)
    {
        await NotificationService.DismissAsync(id, default);
        await LoadAsync();
    }

    private static string GetIcon(string? referenceType) => referenceType switch
    {
        "SalesOrder" => "bi-cart-check",
        "PurchaseOrder" => "bi-truck",
        "ProductionOrder" => "bi-gear",
        "Inventory" or "StockMovement" => "bi-box-seam",
        "QualityCheck" or "InspectionPlan" => "bi-clipboard-check",
        "Employee" => "bi-person",
        "JournalEntry" => "bi-journal-text",
        _ => "bi-bell"
    };

    private static string GetStatusBadge(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Sent" => "bg-success",
        "Failed" => "bg-danger",
        "Read" => "bg-secondary",
        "Dismissed" => "bg-dark",
        _ => "bg-secondary"
    };

    private static string FormatTimeAgo(DateTimeOffset created)
    {
        var diff = DateTimeOffset.UtcNow - created;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return created.ToString("dd.MM.yyyy");
    }
}
