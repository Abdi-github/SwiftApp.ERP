@page "/app/sales/customers/new"
@page "/app/sales/customers/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Sales.Application.DTOs
@using SwiftApp.ERP.Modules.Sales.Application.Services
@attribute [Authorize(Policy = "SALES:CREATE")]
@rendermode InteractiveServer
@inject CustomerService CustomerService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Edit Customer" : "New Customer") — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>@(_isEdit ? "Edit Customer" : "New Customer")</h2>
    <a href="/app/sales/customers" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Customers
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="customerForm">
            <h5 class="mb-3">Company Information</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Company Name</label>
                    <InputText class="form-control" @bind-Value="_model.CompanyName" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">First Name</label>
                    <InputText class="form-control" @bind-Value="_model.FirstName" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Last Name</label>
                    <InputText class="form-control" @bind-Value="_model.LastName" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" type="email" @bind-Value="_model.Email" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Phone</label>
                    <InputText class="form-control" @bind-Value="_model.Phone" />
                </div>
            </div>

            <h5 class="mb-3 mt-2">Address</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Street</label>
                    <InputText class="form-control" @bind-Value="_model.Street" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Postal Code</label>
                    <InputText class="form-control" @bind-Value="_model.PostalCode" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">City</label>
                    <InputText class="form-control" @bind-Value="_model.City" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Canton</label>
                    <InputText class="form-control" @bind-Value="_model.Canton" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Country</label>
                    <InputText class="form-control" @bind-Value="_model.Country" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">VAT Number</label>
                    <InputText class="form-control" @bind-Value="_model.VatNumber" />
                </div>
            </div>

            <h5 class="mb-3 mt-2">Terms</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Payment Terms (days)</label>
                    <InputNumber class="form-control" @bind-Value="_model.PaymentTerms" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Credit Limit (CHF)</label>
                    <InputNumber class="form-control" @bind-Value="_model.CreditLimit" />
                </div>
                <div class="col-md-4 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="_model.Active" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Notes</label>
                <InputTextArea class="form-control" rows="2" @bind-Value="_model.Notes" />
            </div>
            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Update" : "Create")
                </button>
                <a href="/app/sales/customers" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private CustomerFormModel _model = new();
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var c = await CustomerService.GetByIdAsync(Id!.Value);
            if (c is null) { Navigation.NavigateTo("/app/sales/customers"); return; }
            _model = new CustomerFormModel
            {
                CompanyName = c.CompanyName, FirstName = c.FirstName, LastName = c.LastName,
                Email = c.Email, Phone = c.Phone, Street = c.Street, City = c.City,
                PostalCode = c.PostalCode, Canton = c.Canton, Country = c.Country,
                VatNumber = c.VatNumber, PaymentTerms = c.PaymentTerms,
                CreditLimit = c.CreditLimit, Notes = c.Notes, Active = c.Active,
            };
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true; _error = null;
        try
        {
            var request = new CustomerRequest(
                null, _model.CompanyName, _model.FirstName, _model.LastName,
                _model.Email, _model.Phone, _model.Street, _model.City,
                _model.PostalCode, _model.Canton, _model.Country, _model.VatNumber,
                _model.PaymentTerms, _model.CreditLimit, _model.Notes, _model.Active);

            if (_isEdit) await CustomerService.UpdateAsync(Id!.Value, request);
            else await CustomerService.CreateAsync(request);

            Navigation.NavigateTo("/app/sales/customers");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private class CustomerFormModel
    {
        public string? CompanyName { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Street { get; set; }
        public string? City { get; set; }
        public string? PostalCode { get; set; }
        public string? Canton { get; set; }
        public string? Country { get; set; } = "CH";
        public string? VatNumber { get; set; }
        public int PaymentTerms { get; set; } = 30;
        public decimal CreditLimit { get; set; }
        public string? Notes { get; set; }
        public bool Active { get; set; } = true;
    }
}
