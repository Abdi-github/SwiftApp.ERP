@page "/app/sales/customers"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Sales.Application.DTOs
@using SwiftApp.ERP.Modules.Sales.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "SALES:VIEW")]
@rendermode InteractiveServer
@inject CustomerService CustomerService

<PageTitle>Customers — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>Customers</h2>
    <AuthorizeView Policy="SALES:CREATE">
        <a href="/app/sales/customers/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Customer
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search customers..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_activeFilter" @bind:after="OnFilterChanged">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _displayItems.Count == 0)
        {
            <div class="alert alert-info">No customers found.</div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">Showing @_displayItems.Count of @_result.TotalItems records</small>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => Sort("CustomerNumber")'>Customer # @SortIcon("CustomerNumber")</th>
                            <th role="button" @onclick='() => Sort("DisplayName")'>Display Name @SortIcon("DisplayName")</th>
                            <th role="button" @onclick='() => Sort("Email")'>Email @SortIcon("Email")</th>
                            <th>Phone</th>
                            <th role="button" @onclick='() => Sort("City")'>City @SortIcon("City")</th>
                            <th>Active</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _displayItems)
                        {
                            <tr>
                                <td><code>@c.CustomerNumber</code></td>
                                <td>@c.DisplayName</td>
                                <td>@c.Email</td>
                                <td>@c.Phone</td>
                                <td>@c.City</td>
                                <td>
                                    @if (c.Active)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <AuthorizeView Policy="SALES:EDIT">
                                        <a href="/app/sales/customers/edit/@c.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button>
                    </li>
                    @for (int i = 1; i <= _result.TotalPages; i++)
                    {
                        var pg = i;
                        <li class="page-item @(pg == _page ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@code {
    private PagedResult<CustomerResponse>? _result;
    private List<CustomerResponse> _displayItems = [];
    private string? _search;
    private string _activeFilter = "";
    private string _sortColumn = "DisplayName";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        _result = await CustomerService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientFilters();
        _loading = false;
    }

    private void ApplyClientFilters()
    {
        if (_result is null) { _displayItems = []; return; }
        IEnumerable<CustomerResponse> items = _result.Items;
        if (_activeFilter == "active") items = items.Where(c => c.Active);
        else if (_activeFilter == "inactive") items = items.Where(c => !c.Active);
        _displayItems = ApplySort(items).ToList();
    }

    private IEnumerable<CustomerResponse> ApplySort(IEnumerable<CustomerResponse> items) => _sortColumn switch
    {
        "CustomerNumber" => _sortAsc ? items.OrderBy(c => c.CustomerNumber) : items.OrderByDescending(c => c.CustomerNumber),
        "DisplayName" => _sortAsc ? items.OrderBy(c => c.DisplayName) : items.OrderByDescending(c => c.DisplayName),
        "Email" => _sortAsc ? items.OrderBy(c => c.Email) : items.OrderByDescending(c => c.Email),
        "City" => _sortAsc ? items.OrderBy(c => c.City) : items.OrderByDescending(c => c.City),
        _ => items
    };

    private void Sort(string column)
    {
        if (_sortColumn == column) _sortAsc = !_sortAsc;
        else { _sortColumn = column; _sortAsc = true; }
        ApplyClientFilters();
    }

    private MarkupString SortIcon(string column) =>
        _sortColumn != column ? new("⇅") : new(_sortAsc ? "↑" : "↓");

    private async Task OnFilterChanged() { _page = 1; await LoadData(); }

    private void SearchChanged()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Stop();
            _page = 1;
            await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || (_result is not null && page > _result.TotalPages)) return;
        _page = page;
        await LoadData();
    }
}
