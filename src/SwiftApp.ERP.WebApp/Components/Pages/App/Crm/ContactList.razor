@page "/app/crm/contacts"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Crm.Application.DTOs
@using SwiftApp.ERP.Modules.Crm.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "CRM:VIEW")]
@rendermode InteractiveServer
@inject ContactService ContactService

<PageTitle>Contacts — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-lines-fill me-2"></i>Contacts</h2>
    <AuthorizeView Policy="CRM:CREATE">
        <a href="/app/crm/contacts/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Contact
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search contacts..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No contacts found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("DisplayName")'>Name @SortIcon("DisplayName")</th>
                            <th role="button" @onclick='() => ToggleSort("Company")'>Company @SortIcon("Company")</th>
                            <th role="button" @onclick='() => ToggleSort("Position")'>Position @SortIcon("Position")</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th role="button" @onclick='() => ToggleSort("City")'>City @SortIcon("City")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _sorted)
                        {
                            <tr>
                                <td>@c.DisplayName</td>
                                <td>@(c.Company ?? "—")</td>
                                <td>@(c.Position ?? "—")</td>
                                <td>@(c.Email ?? "—")</td>
                                <td>@(c.Phone ?? "—")</td>
                                <td>@(c.City ?? "—")</td>
                                <td class="text-end">
                                    <AuthorizeView Policy="CRM:EDIT">
                                        <a href="/app/crm/contacts/edit/@c.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int i = 1; i <= _result.TotalPages; i++) { var pg = i; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<ContactResponse>? _result;
    private List<ContactResponse> _sorted = [];
    private string? _search;
    private string _sortCol = "DisplayName";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await ContactService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        _sorted = (_sortCol switch
        {
            "DisplayName" => _sortAsc ? _result.Items.OrderBy(c => c.DisplayName) : _result.Items.OrderByDescending(c => c.DisplayName),
            "Company" => _sortAsc ? _result.Items.OrderBy(c => c.Company) : _result.Items.OrderByDescending(c => c.Company),
            "Position" => _sortAsc ? _result.Items.OrderBy(c => c.Position) : _result.Items.OrderByDescending(c => c.Position),
            "City" => _sortAsc ? _result.Items.OrderBy(c => c.City) : _result.Items.OrderByDescending(c => c.City),
            _ => _result.Items.AsEnumerable()
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
