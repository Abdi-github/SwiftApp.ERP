@page "/app/inventory/warehouses"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Inventory.Application.DTOs
@using SwiftApp.ERP.Modules.Inventory.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "INVENTORY:VIEW")]
@rendermode InteractiveServer
@inject WarehouseService WarehouseService

<PageTitle>Warehouses — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building me-2"></i>Warehouses</h2>
    <AuthorizeView Policy="INVENTORY:CREATE">
        <a href="/app/inventory/warehouses/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Warehouse
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search warehouses..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No warehouses found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("Code")'>Code @SortIcon("Code")</th>
                            <th role="button" @onclick='() => ToggleSort("Name")'>Name @SortIcon("Name")</th>
                            <th>Address</th>
                            <th role="button" @onclick='() => ToggleSort("Active")'>Active @SortIcon("Active")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in _sorted)
                        {
                            <tr>
                                <td><code>@w.Code</code></td>
                                <td>@w.Name</td>
                                <td>@(w.Address ?? "—")</td>
                                <td><span class="badge @(w.Active ? "bg-success" : "bg-danger")">@(w.Active ? "Active" : "Inactive")</span></td>
                                <td class="text-end">
                                    <AuthorizeView Policy="INVENTORY:EDIT">
                                        <a href="/app/inventory/warehouses/edit/@w.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="INVENTORY:DELETE">
                                        <a href="/app/inventory/warehouses/delete/@w.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button>
                        </li>
                        @for (int i = 1; i <= _result.TotalPages; i++)
                        {
                            var pg = i;
                            <li class="page-item @(pg == _page ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                            </li>
                        }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<WarehouseResponse>? _result;
    private List<WarehouseResponse> _sorted = [];
    private string? _search;
    private string _statusFilter = "";
    private string _sortCol = "Code";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        _result = await WarehouseService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort();
        _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        IEnumerable<WarehouseResponse> items = _result.Items;
        if (_statusFilter == "active") items = items.Where(w => w.Active);
        else if (_statusFilter == "inactive") items = items.Where(w => !w.Active);
        _sorted = (_sortCol switch
        {
            "Code" => _sortAsc ? items.OrderBy(w => w.Code) : items.OrderByDescending(w => w.Code),
            "Name" => _sortAsc ? items.OrderBy(w => w.Name) : items.OrderByDescending(w => w.Name),
            "Active" => _sortAsc ? items.OrderBy(w => w.Active) : items.OrderByDescending(w => w.Active),
            _ => items
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");

    private async Task OnFilterChanged() { _page = 1; await LoadData(); }

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
