@page "/app/inventory/stock-movements"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Inventory.Application.DTOs
@using SwiftApp.ERP.Modules.Inventory.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "INVENTORY:VIEW")]
@rendermode InteractiveServer
@inject StockService StockService

<PageTitle>Stock Movements — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-arrow-left-right me-2"></i>Stock Movements</h2>
    <AuthorizeView Policy="INVENTORY:CREATE">
        <a href="/app/inventory/stock-movements/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Movement
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search movements..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No stock movements found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("ReferenceNumber")'>Reference @SortIcon("ReferenceNumber")</th>
                            <th role="button" @onclick='() => ToggleSort("MovementType")'>Type @SortIcon("MovementType")</th>
                            <th>Item</th>
                            <th>Source</th>
                            <th>Target</th>
                            <th role="button" @onclick='() => ToggleSort("Quantity")'>Qty @SortIcon("Quantity")</th>
                            <th role="button" @onclick='() => ToggleSort("MovementDate")'>Date @SortIcon("MovementDate")</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _sorted)
                        {
                            <tr>
                                <td><code>@m.ReferenceNumber</code></td>
                                <td><span class="badge @GetTypeBadge(m.MovementType)">@m.MovementType</span></td>
                                <td>@m.ItemType</td>
                                <td>@(m.SourceWarehouseCode ?? "—")</td>
                                <td>@(m.TargetWarehouseCode ?? "—")</td>
                                <td class="text-end">@m.Quantity.ToString("N2")</td>
                                <td>@m.MovementDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@(m.Reason ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int p = 1; p <= _result.TotalPages; p++) { var pg = p; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<StockMovementResponse>? _result;
    private List<StockMovementResponse> _sorted = [];
    private string? _search;
    private string _sortCol = "MovementDate";
    private bool _sortAsc;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await StockService.GetMovementsPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        _sorted = (_sortCol switch
        {
            "ReferenceNumber" => _sortAsc ? _result.Items.OrderBy(m => m.ReferenceNumber) : _result.Items.OrderByDescending(m => m.ReferenceNumber),
            "MovementType" => _sortAsc ? _result.Items.OrderBy(m => m.MovementType) : _result.Items.OrderByDescending(m => m.MovementType),
            "Quantity" => _sortAsc ? _result.Items.OrderBy(m => m.Quantity) : _result.Items.OrderByDescending(m => m.Quantity),
            "MovementDate" => _sortAsc ? _result.Items.OrderBy(m => m.MovementDate) : _result.Items.OrderByDescending(m => m.MovementDate),
            _ => _result.Items.AsEnumerable()
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");

    private static string GetTypeBadge(string type) => type switch
    {
        "GoodsReceipt" or "ProductionReceipt" or "Return" => "bg-success",
        "GoodsIssue" or "ProductionIssue" or "Shipment" or "Scrap" => "bg-danger",
        "Transfer" => "bg-primary",
        "Adjustment" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
