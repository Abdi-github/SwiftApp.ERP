@page "/app/admin/users"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Auth.Application.DTOs
@using SwiftApp.ERP.Modules.Auth.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "ADMIN:USERS_MANAGE")]
@rendermode InteractiveServer
@inject UserService UserService

<PageTitle>User Management — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-badge me-2"></i>Users</h2>
    <AuthorizeView Policy="ADMIN:USERS_MANAGE">
        <a href="/app/admin/users/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New User
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search users..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Status</option>
                    <option value="enabled">Enabled</option>
                    <option value="disabled">Disabled</option>
                    <option value="locked">Locked</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _result.Items.Count == 0)
        {
            <div class="alert alert-info">No users found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalItems)) of @_result.TotalItems records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("Username")'>Username @SortIcon("Username")</th>
                            <th role="button" @onclick='() => ToggleSort("DisplayName")'>Name @SortIcon("DisplayName")</th>
                            <th role="button" @onclick='() => ToggleSort("Email")'>Email @SortIcon("Email")</th>
                            <th>Roles</th>
                            <th role="button" @onclick='() => ToggleSort("Enabled")'>Enabled @SortIcon("Enabled")</th>
                            <th>Locked</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _sorted)
                        {
                            <tr>
                                <td><code>@user.Username</code></td>
                                <td>@user.DisplayName</td>
                                <td>@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-primary me-1">@role</span>
                                    }
                                </td>
                                <td><span class="badge @(user.Enabled ? "bg-success" : "bg-danger")">@(user.Enabled ? "Enabled" : "Disabled")</span></td>
                                <td>
                                    @if (user.Locked)
                                    {
                                        <span class="badge bg-warning text-dark">Locked</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <AuthorizeView Policy="ADMIN:USERS_MANAGE">
                                        <a href="/app/admin/users/edit/@user.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(_page <= 1 ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button></li>
                        @for (int i = 1; i <= _result.TotalPages; i++) { var pg = i; <li class="page-item @(pg == _page ? "active" : "")"><button class="page-link" @onclick="() => GoToPage(pg)">@pg</button></li> }
                        <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")"><button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@code {
    private PagedResult<UserResponse>? _result;
    private List<UserResponse> _sorted = [];
    private string? _search;
    private string _statusFilter = "";
    private string _sortCol = "Username";
    private bool _sortAsc = true;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; StateHasChanged();
        _result = await UserService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientSort(); _loading = false;
    }

    private void ApplyClientSort()
    {
        if (_result is null) { _sorted = []; return; }
        IEnumerable<UserResponse> items = _result.Items;
        if (_statusFilter == "enabled") items = items.Where(u => u.Enabled);
        else if (_statusFilter == "disabled") items = items.Where(u => !u.Enabled);
        else if (_statusFilter == "locked") items = items.Where(u => u.Locked);
        _sorted = (_sortCol switch
        {
            "Username" => _sortAsc ? items.OrderBy(u => u.Username) : items.OrderByDescending(u => u.Username),
            "DisplayName" => _sortAsc ? items.OrderBy(u => u.DisplayName) : items.OrderByDescending(u => u.DisplayName),
            "Email" => _sortAsc ? items.OrderBy(u => u.Email) : items.OrderByDescending(u => u.Email),
            "Enabled" => _sortAsc ? items.OrderBy(u => u.Enabled) : items.OrderByDescending(u => u.Enabled),
            _ => items
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");
    private async Task OnFilterChanged() { _page = 1; await LoadData(); }

    private void SearchChanged()
    {
        _debounceTimer?.Stop(); _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) => { _debounceTimer?.Stop(); _page = 1; await InvokeAsync(async () => { await LoadData(); StateHasChanged(); }); };
        _debounceTimer.AutoReset = false; _debounceTimer.Start();
    }

    private async Task GoToPage(int page) { if (page < 1 || (_result is not null && page > _result.TotalPages)) return; _page = page; await LoadData(); }
}
