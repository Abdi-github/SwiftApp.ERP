@page "/app/masterdata/products/{ProductId:guid}/bom"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:VIEW")]
@rendermode InteractiveServer
@inject BillOfMaterialService BomService
@inject ProductService ProductService
@inject NavigationManager Nav

<PageTitle>Bill of Materials — SwiftApp ERP</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/app/masterdata/products">Products</a></li>
        <li class="breadcrumb-item active">Bill of Materials</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2><i class="bi bi-diagram-3 me-2"></i>Bill of Materials</h2>
        @if (_productName is not null)
        {
            <p class="text-muted mb-0">Product: <strong>@_productName</strong></p>
        }
    </div>
    <AuthorizeView Policy="MASTERDATA:CREATE">
        <a href="/app/masterdata/products/@ProductId/bom/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Material
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="alert alert-info">No materials in this bill of materials yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Pos</th>
                            <th>Material SKU</th>
                            <th>Material Name</th>
                            <th class="text-end">Quantity</th>
                            <th>Unit</th>
                            <th>Notes</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _items.OrderBy(b => b.Position))
                        {
                            <tr>
                                <td>@item.Position</td>
                                <td><code>@item.MaterialSku</code></td>
                                <td>@item.MaterialName</td>
                                <td class="text-end">@item.Quantity.ToString("N2")</td>
                                <td>@(item.UnitOfMeasureCode ?? "—")</td>
                                <td class="text-muted">@(item.Notes ?? "—")</td>
                                <td class="text-end">
                                    <AuthorizeView Policy="MASTERDATA:EDIT">
                                        <a href="/app/masterdata/products/@ProductId/bom/edit/@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="MASTERDATA:DELETE">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid ProductId { get; set; }

    private List<BillOfMaterialResponse> _items = [];
    private string? _productName;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var product = await ProductService.GetByIdAsync(ProductId);
        _productName = product?.Name;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _items = await BomService.GetByProductIdAsync(ProductId);
        _loading = false;
    }

    private async Task DeleteAsync(Guid id)
    {
        await BomService.DeleteAsync(id);
        await LoadDataAsync();
    }
}
