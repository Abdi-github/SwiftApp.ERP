@page "/app/masterdata/products/delete/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:DELETE")]
@rendermode InteractiveServer
@inject ProductService ProductService
@inject NavigationManager Navigation

<PageTitle>Delete Product — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-trash me-2"></i>Delete Product</h2>
    <a href="/app/masterdata/products" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
    </div>
}

@if (_product is not null)
{
    <div class="card border-danger">
        <div class="card-body">
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Are you sure you want to delete the product <strong>@_product.Name</strong> (SKU: @_product.Sku)?
                This action cannot be undone.
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-3">SKU</dt><dd class="col-sm-9"><code>@_product.Sku</code></dd>
                <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@_product.Name</dd>
                <dt class="col-sm-3">Category</dt><dd class="col-sm-9">@(_product.CategoryName ?? "—")</dd>
                <dt class="col-sm-3">Unit Price</dt><dd class="col-sm-9">CHF @_product.UnitPrice.ToString("N2")</dd>
                <dt class="col-sm-3">List Price</dt><dd class="col-sm-9">CHF @_product.ListPrice.ToString("N2")</dd>
            </dl>
            <hr />
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                    @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
                <a href="/app/masterdata/products" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProductResponse? _product;
    private string? _error;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        _product = await ProductService.GetByIdAsync(Id);
        if (_product is null) Navigation.NavigateTo("/app/masterdata/products");
    }

    private async Task ConfirmDelete()
    {
        _deleting = true;
        _error = null;
        try
        {
            await ProductService.DeleteAsync(Id);
            Navigation.NavigateTo("/app/masterdata/products");
        }
        catch (Exception ex) { _error = ex.Message; _deleting = false; }
    }
}
