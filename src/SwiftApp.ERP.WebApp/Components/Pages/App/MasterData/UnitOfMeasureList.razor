@page "/app/masterdata/units-of-measure"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:VIEW")]
@rendermode InteractiveServer
@inject UnitOfMeasureService UomService

<PageTitle>Units of Measure — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-rulers me-2"></i>Units of Measure</h2>
    <AuthorizeView Policy="MASTERDATA:CREATE">
        <a href="/app/masterdata/units-of-measure/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Unit
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="alert alert-info">No units of measure found.</div>
        }
        else
        {
            <small class="text-muted d-block mb-2">@_items.Count records</small>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => ToggleSort("Code")'>Code @SortIcon("Code")</th>
                            <th role="button" @onclick='() => ToggleSort("Name")'>Name @SortIcon("Name")</th>
                            <th>Description</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in _sorted)
                        {
                            <tr>
                                <td><code>@u.Code</code></td>
                                <td>@u.Name</td>
                                <td>@(u.Description ?? "—")</td>
                                <td>@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <AuthorizeView Policy="MASTERDATA:EDIT">
                                        <a href="/app/masterdata/units-of-measure/edit/@u.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<UnitOfMeasureResponse> _items = [];
    private List<UnitOfMeasureResponse> _sorted = [];
    private string _sortCol = "Code";
    private bool _sortAsc = true;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _items = await UomService.GetAllAsync();
        ApplyClientSort();
        _loading = false;
    }

    private void ApplyClientSort()
    {
        _sorted = (_sortCol switch
        {
            "Code" => _sortAsc ? _items.OrderBy(u => u.Code) : _items.OrderByDescending(u => u.Code),
            "Name" => _sortAsc ? _items.OrderBy(u => u.Name) : _items.OrderByDescending(u => u.Name),
            _ => _items.AsEnumerable()
        }).ToList();
    }

    private void ToggleSort(string col) { if (_sortCol == col) _sortAsc = !_sortAsc; else { _sortCol = col; _sortAsc = true; } ApplyClientSort(); }
    private MarkupString SortIcon(string col) => new(_sortCol != col ? "<i class=\"bi bi-arrow-down-up text-muted small\"></i>" : _sortAsc ? "<i class=\"bi bi-sort-up\"></i>" : "<i class=\"bi bi-sort-down\"></i>");
}
