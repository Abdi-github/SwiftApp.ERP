@page "/app/masterdata/materials/delete/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:DELETE")]
@rendermode InteractiveServer
@inject MaterialService MaterialService
@inject NavigationManager Navigation

<PageTitle>Delete Material — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-trash me-2"></i>Delete Material</h2>
    <a href="/app/masterdata/materials" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Materials
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@_error</div>
}

@if (_material is not null)
{
    <div class="card border-danger">
        <div class="card-body">
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Are you sure you want to delete the material <strong>@_material.Name</strong> (SKU: @_material.Sku)?
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-3">SKU</dt><dd class="col-sm-9"><code>@_material.Sku</code></dd>
                <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@_material.Name</dd>
                <dt class="col-sm-3">Unit Price</dt><dd class="col-sm-9">CHF @_material.UnitPrice.ToString("N2")</dd>
            </dl>
            <hr />
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                    @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
                <a href="/app/masterdata/materials" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MaterialResponse? _material;
    private string? _error;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        _material = await MaterialService.GetByIdAsync(Id);
        if (_material is null) Navigation.NavigateTo("/app/masterdata/materials");
    }

    private async Task ConfirmDelete()
    {
        _deleting = true; _error = null;
        try { await MaterialService.DeleteAsync(Id); Navigation.NavigateTo("/app/masterdata/materials"); }
        catch (Exception ex) { _error = ex.Message; _deleting = false; }
    }
}
