@page "/app/masterdata/units-of-measure/new"
@page "/app/masterdata/units-of-measure/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:CREATE")]
@rendermode InteractiveServer
@inject UnitOfMeasureService UomService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Edit Unit of Measure" : "New Unit of Measure") — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-rulers me-2"></i>@(_isEdit ? "Edit Unit of Measure" : "New Unit of Measure")</h2>
    <a href="/app/masterdata/units-of-measure" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Units
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="uomForm">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Code <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Code" />
                </div>
                <div class="col-md-8 mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Name" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" />
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Update" : "Create")
                </button>
                <a href="/app/masterdata/units-of-measure" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private UomFormModel _model = new();
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var u = await UomService.GetByIdAsync(Id!.Value);
            if (u is null) { Navigation.NavigateTo("/app/masterdata/units-of-measure"); return; }
            _model = new UomFormModel { Code = u.Code, Name = u.Name, Description = u.Description };
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true; _error = null;
        try
        {
            var request = new UnitOfMeasureRequest(
                _model.Code ?? "", _model.Name ?? "", _model.Description, null, null);

            if (_isEdit) await UomService.UpdateAsync(Id!.Value, request);
            else await UomService.CreateAsync(request);

            Navigation.NavigateTo("/app/masterdata/units-of-measure");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private class UomFormModel
    {
        public string? Code { get; set; }
        public string? Name { get; set; }
        public string? Description { get; set; }
    }
}
