@page "/app/masterdata/categories/delete/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@attribute [Authorize(Policy = "MASTERDATA:DELETE")]
@rendermode InteractiveServer
@inject CategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Delete Category — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-trash me-2"></i>Delete Category</h2>
    <a href="/app/masterdata/categories" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Categories
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@_error</div>
}

@if (_category is not null)
{
    <div class="card border-danger">
        <div class="card-body">
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Are you sure you want to delete the category <strong>@_category.Name</strong>?
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@_category.Name</dd>
                <dt class="col-sm-3">Parent</dt><dd class="col-sm-9">@(_category.ParentCategoryName ?? "— Root —")</dd>
                <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@(_category.Description ?? "—")</dd>
            </dl>
            <hr />
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                    @if (_deleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
                <a href="/app/masterdata/categories" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private CategoryResponse? _category;
    private string? _error;
    private bool _deleting;

    protected override async Task OnInitializedAsync()
    {
        _category = await CategoryService.GetByIdAsync(Id);
        if (_category is null) Navigation.NavigateTo("/app/masterdata/categories");
    }

    private async Task ConfirmDelete()
    {
        _deleting = true; _error = null;
        try { await CategoryService.DeleteAsync(Id); Navigation.NavigateTo("/app/masterdata/categories"); }
        catch (Exception ex) { _error = ex.Message; _deleting = false; }
    }
}
