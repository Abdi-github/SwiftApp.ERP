@page "/app/masterdata/products/new"
@page "/app/masterdata/products/edit/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.MasterData.Application.DTOs
@using SwiftApp.ERP.Modules.MasterData.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "MASTERDATA:CREATE")]
@rendermode InteractiveServer
@inject ProductService ProductService
@inject CategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>@(_isEdit ? "Edit Product" : "New Product") — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-watch me-2"></i>@(_isEdit ? "Edit Product" : "New Product")</h2>
    <a href="/app/masterdata/products" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-1"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="productForm">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">SKU <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Sku" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_model.Name" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Category</label>
                    <InputSelect class="form-select" @bind-Value="_model.CategoryId">
                        <option value="">— None —</option>
                        @foreach (var c in _categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Unit Price (CHF) <span class="text-danger">*</span></label>
                    <InputNumber class="form-control" @bind-Value="_model.UnitPrice" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">List Price (CHF) <span class="text-danger">*</span></label>
                    <InputNumber class="form-control" @bind-Value="_model.ListPrice" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">VAT Rate <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="_model.VatRate">
                        @foreach (var v in Enum.GetValues<VatRate>())
                        {
                            <option value="@v">@v</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="_model.Active" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Update" : "Create")
                </button>
                <a href="/app/masterdata/products" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private ProductFormModel _model = new();
    private List<CategoryResponse> _categories = [];
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategoryService.GetAllAsync();

        if (_isEdit)
        {
            var product = await ProductService.GetByIdAsync(Id!.Value);
            if (product is null) { Navigation.NavigateTo("/app/masterdata/products"); return; }
            _model = new ProductFormModel
            {
                Sku = product.Sku,
                Name = product.Name,
                Description = product.Description,
                CategoryId = product.CategoryId?.ToString() ?? "",
                UnitPrice = product.UnitPrice,
                ListPrice = product.ListPrice,
                VatRate = Enum.TryParse<VatRate>(product.VatRate, out var vr) ? vr : VatRate.Standard,
                Active = product.Active,
            };
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true;
        _error = null;
        try
        {
            Guid? categoryId = Guid.TryParse(_model.CategoryId, out var cid) ? cid : null;
            var request = new ProductRequest(
                _model.Sku, _model.Name, _model.Description, categoryId,
                _model.UnitPrice, _model.ListPrice, _model.VatRate, _model.Active, null, null);

            if (_isEdit)
                await ProductService.UpdateAsync(Id!.Value, request);
            else
                await ProductService.CreateAsync(request);

            Navigation.NavigateTo("/app/masterdata/products");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private class ProductFormModel
    {
        public string Sku { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string CategoryId { get; set; } = "";
        public decimal UnitPrice { get; set; }
        public decimal ListPrice { get; set; }
        public VatRate VatRate { get; set; } = VatRate.Standard;
        public bool Active { get; set; } = true;
    }
}
