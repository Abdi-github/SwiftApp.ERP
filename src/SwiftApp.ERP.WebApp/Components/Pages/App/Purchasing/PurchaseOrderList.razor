@page "/app/purchasing/orders"
@using Microsoft.AspNetCore.Authorization
@using SwiftApp.ERP.Modules.Purchasing.Application.DTOs
@using SwiftApp.ERP.Modules.Purchasing.Application.Services
@using SwiftApp.ERP.SharedKernel.Domain
@attribute [Authorize(Policy = "PURCHASING:VIEW")]
@rendermode InteractiveServer
@inject PurchaseOrderService PurchaseOrderService

<PageTitle>Purchase Orders — SwiftApp ERP</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-bag me-2"></i>Purchase Orders</h2>
    <AuthorizeView Policy="PURCHASING:CREATE">
        <a href="/app/purchasing/orders/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Order
        </a>
    </AuthorizeView>
</div>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search purchase orders..." @bind="_search" @bind:event="oninput" @bind:after="SearchChanged" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    <option value="DRAFT">Draft</option>
                    <option value="CONFIRMED">Confirmed</option>
                    <option value="PROCESSING">Processing</option>
                    <option value="SHIPPED">Shipped</option>
                    <option value="DELIVERED">Delivered</option>
                    <option value="COMPLETED">Completed</option>
                    <option value="CANCELLED">Cancelled</option>
                </select>
            </div>
        </div>

        @if (_loading)
        {
            <div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>
        }
        else if (_result is null || _displayItems.Count == 0)
        {
            <div class="alert alert-info">No purchase orders found.</div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">Showing @_displayItems.Count of @_result.TotalItems records</small>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th role="button" @onclick='() => Sort("OrderNumber")'>Order # @SortIcon("OrderNumber")</th>
                            <th role="button" @onclick='() => Sort("SupplierName")'>Supplier @SortIcon("SupplierName")</th>
                            <th role="button" @onclick='() => Sort("Status")'>Status @SortIcon("Status")</th>
                            <th role="button" @onclick='() => Sort("OrderDate")'>Order Date @SortIcon("OrderDate")</th>
                            <th role="button" @onclick='() => Sort("ExpectedDeliveryDate")'>Expected Delivery @SortIcon("ExpectedDeliveryDate")</th>
                            <th class="text-end" role="button" @onclick='() => Sort("TotalAmount")'>Total @SortIcon("TotalAmount")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _displayItems)
                        {
                            <tr>
                                <td><code>@o.OrderNumber</code></td>
                                <td>@o.SupplierName</td>
                                <td><span class="badge @GetStatusBadge(o.Status)">@o.Status</span></td>
                                <td>@o.OrderDate.ToString("dd.MM.yyyy")</td>
                                <td>@(o.ExpectedDeliveryDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                                <td class="text-end">CHF @o.TotalAmount.ToString("N2")</td>
                                <td class="text-end">
                                    <AuthorizeView Policy="PURCHASING:EDIT">
                                        <a href="/app/purchasing/orders/edit/@o.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button>
                    </li>
                    @for (int i = 1; i <= _result.TotalPages; i++)
                    {
                        var pg = i;
                        <li class="page-item @(pg == _page ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@code {
    private PagedResult<PurchaseOrderResponse>? _result;
    private List<PurchaseOrderResponse> _displayItems = [];
    private string? _search;
    private string _statusFilter = "";
    private string _sortColumn = "OrderDate";
    private bool _sortAsc = false;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = true;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        _result = await PurchaseOrderService.GetPagedAsync(_page, PageSize, _search);
        ApplyClientFilters();
        _loading = false;
    }

    private void ApplyClientFilters()
    {
        if (_result is null) { _displayItems = []; return; }
        IEnumerable<PurchaseOrderResponse> items = _result.Items;
        if (!string.IsNullOrWhiteSpace(_statusFilter))
            items = items.Where(o => o.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase));
        _displayItems = ApplySort(items).ToList();
    }

    private IEnumerable<PurchaseOrderResponse> ApplySort(IEnumerable<PurchaseOrderResponse> items) => _sortColumn switch
    {
        "OrderNumber" => _sortAsc ? items.OrderBy(o => o.OrderNumber) : items.OrderByDescending(o => o.OrderNumber),
        "SupplierName" => _sortAsc ? items.OrderBy(o => o.SupplierName) : items.OrderByDescending(o => o.SupplierName),
        "Status" => _sortAsc ? items.OrderBy(o => o.Status) : items.OrderByDescending(o => o.Status),
        "OrderDate" => _sortAsc ? items.OrderBy(o => o.OrderDate) : items.OrderByDescending(o => o.OrderDate),
        "ExpectedDeliveryDate" => _sortAsc ? items.OrderBy(o => o.ExpectedDeliveryDate) : items.OrderByDescending(o => o.ExpectedDeliveryDate),
        "TotalAmount" => _sortAsc ? items.OrderBy(o => o.TotalAmount) : items.OrderByDescending(o => o.TotalAmount),
        _ => items
    };

    private void Sort(string column)
    {
        if (_sortColumn == column) _sortAsc = !_sortAsc;
        else { _sortColumn = column; _sortAsc = true; }
        ApplyClientFilters();
    }

    private MarkupString SortIcon(string column) =>
        _sortColumn != column ? new("⇅") : new(_sortAsc ? "↑" : "↓");

    private async Task OnFilterChanged() { _page = 1; await LoadData(); }

    private void SearchChanged()
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Stop();
            _page = 1;
            await InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || (_result is not null && page > _result.TotalPages)) return;
        _page = page;
        await LoadData();
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "DRAFT" => "bg-secondary",
        "CONFIRMED" => "bg-primary",
        "PROCESSING" => "bg-info",
        "SHIPPED" => "bg-warning text-dark",
        "DELIVERED" => "bg-success",
        "COMPLETED" => "bg-success",
        "CANCELLED" => "bg-danger",
        _ => "bg-secondary"
    };
}
