{
    // ── Memory optimization for 11GB RAM system ──
    // Reduce Roslyn language server memory (biggest consumer ~900MB)
    "dotnet.server.useOmnisharp": false,
    "csharp.maxProjectFileCountForDiagnosticAnalysis": 500,
    "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "openFiles",
    "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "openFiles",
    // Reduce file watcher scope (saves memory + CPU)
    "files.watcherExclude": {
        "**/bin/**": true,
        "**/obj/**": true,
        "**/node_modules/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/docker/**": true,
        "**/tests/**/bin/**": true,
        "**/tests/**/obj/**": true,
        "**/TestResults/**": true,
        "**/packages/**": true,
        "**/.nuget/**": true
    },
    // Exclude from search
    "search.exclude": {
        "**/bin": true,
        "**/obj": true,
        "**/node_modules": true,
        "**/TestResults": true,
        "**/.git": true
    },
    // Reduce editor memory usage
    "editor.maxTokenizationLineLength": 5000,
    "editor.largeFileOptimizations": true,
    // Limit git memory usage
    "git.autoRepositoryDetection": "openEditors",
    // Reduce file watcher polling (less CPU thrashing)
    "files.watcherPollingInterval": 5000
}