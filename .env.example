# SwiftApp ERP — .env.example
# Copy to .env (dev) or .env.prod (production) and fill in values.

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=swiftapp_erp
POSTGRES_USER=erp_admin
POSTGRES_PASSWORD=erp_secret

# ── JWT Authentication ────────────────────────────────────
JWT_SECRET=SwiftAppErpSecretKeyForJwtTokenGeneration2026CH
JWT_EXPIRATION_MINUTES=1440

# ── Email ─────────────────────────────────────────────────
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@swiftapp.ch

# ── pgAdmin ──────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@swiftapp.ch
PGADMIN_DEFAULT_PASSWORD=admin
